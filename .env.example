# Database
# For local dev without DB, the app uses fallback data automatically.
# For Railway production: add PostgreSQL plugin and set DATABASE_URL.
DATABASE_URL="postgresql://user:password@host:port/dbname"

# NextAuth
NEXTAUTH_SECRET="almuna-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Environment
NODE_ENV="development"
