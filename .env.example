# Database
# For local SQLite (default):
DATABASE_URL="file:./app.db"

# For Railway production with PostgreSQL:
# 1. Add PostgreSQL plugin in Railway
# 2. Railway will set DATABASE_URL automatically
# 3. Change provider in prisma/schema.prisma from "sqlite" to "postgresql"
# DATABASE_URL="postgresql://user:password@host:port/dbname"

# NextAuth.js
NEXTAUTH_SECRET="generate-a-random-secret-here-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Environment
NODE_ENV="development"
