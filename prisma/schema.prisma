generator client {
  provider = "prisma-client-js"
}

// For Railway production with PostgreSQL:
//   1. Change provider to "postgresql"
//   2. Add a PostgreSQL database in Railway
//   3. Set DATABASE_URL to the Railway PostgreSQL connection string
// For local development, SQLite works fine with file:./app.db
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}
